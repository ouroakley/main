[
    {{- range $index, $organiser := .Pages }}
    {{- if $index }}, {{ end }}
    {
        "title": "{{ .Title }}",
        {{- with .File }}
        "baseName": "{{ .ContentBaseName }}",
        "slug": "{{ path.Base .Dir }}"
        {{- else }}
        "baseName": "",
        "slug": ""
        {{- end }}
    }
    {{- end }}
]
